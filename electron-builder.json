{
    "productName": "Maverick Client for Everest",
    "appId": "com.maverick.everest",
    "directories": {
        "output": "dist"
    },
    "files": [
        "out/**/*",
        "package.json"
    ],
    "extraResources": [
        {
            "from": "maverick-ndi/build/Release",
            "filter": [
                "ndi-bridge.exe",
                "*.dll"
            ],
            "to": "ndi-bridge"
        }
    ],
    "win": {
        "target": [
            "portable"
        ]
    },
    "mac": {
        "target": [
            "dmg"
        ],
        "hardenedRuntime": true,
        "entitlements": "build/entitlements.mac.plist"
    },
    "linux": {
        "target": [
            "AppImage"
        ]
    }
}