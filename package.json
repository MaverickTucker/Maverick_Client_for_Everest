{
  "name": "maverick-client-for-everest",
  "version": "1.0.0",
  "description": "Maverick Client for Everest Broadcast Graphics",
  "main": "./out/main/index.js",
  "author": "Maverick Development Team",
  "type": "module",
  "scripts": {
    "format": "prettier --write .",
    "lint": "eslint . --ext .js,.jsx,.cjs,.mjs,.ts,.tsx,.cts,.mts --fix",
    "typecheck:node": "tsc --noEmit -p src/main/tsconfig.json && tsc --noEmit -p src/preload/tsconfig.json",
    "typecheck:renderer": "tsc --noEmit -p src/renderer/tsconfig.json",
    "typecheck": "npm run typecheck:node && npm run typecheck:renderer",
    "start": "electron-vite preview",
    "dev": "electron-vite dev",
    "build": "npm run typecheck && electron-vite build",
    "postinstall": "electron-builder install-app-deps",
    "build:win": "npm run build && electron-builder --win --config",
    "build:mac": "npm run build && electron-builder --mac --config",
    "build:linux": "npm run build && electron-builder --linux --config"
  },
  "dependencies": {
    "@electron-toolkit/preload": "^3.0.1",
    "@electron-toolkit/utils": "^3.0.0",
    "@tanstack/react-query": "^5.67.2",
    "@tanstack/react-router": "^1.112.1",
    "@tanstack/react-table": "^8.21.2",
    "axios": "^1.8.2",
    "clsx": "^2.1.1",
    "electron-log": "^5.3.1",
    "electron-store": "^10.0.0",
    "lucide-react": "^0.479.0",
    "react-hook-form": "^7.54.2",
    "react-resizable-panels": "^4.9.0",
    "socket.io-client": "^4.8.1",
    "sonner": "^2.0.1",
    "tailwind-merge": "^3.0.2",
    "zod": "^3.24.2",
    "zustand": "^5.0.3"
  },
  "devDependencies": {
    "@electron-toolkit/eslint-config-prettier": "^2.0.0",
    "@electron-toolkit/eslint-config-ts": "^2.0.0",
    "@electron-toolkit/tsconfig": "^1.0.1",
    "@types/node": "^22.13.10",
    "@types/react": "^19.0.10",
    "@types/react-dom": "^19.0.4",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "electron": "^34.3.0",
    "electron-builder": "^25.1.8",
    "electron-vite": "^2.3.0",
    "eslint": "^9.21.0",
    "eslint-plugin-react": "^7.37.4",
    "javascript-obfuscator": "^5.4.1",
    "postcss": "^8.5.3",
    "prettier": "^3.5.3",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "rollup-plugin-javascript-obfuscator": "^1.0.4",
    "tailwindcss": "^4.0.11",
    "typescript": "^5.8.2",
    "vite": "^6.2.1"
  }
}
