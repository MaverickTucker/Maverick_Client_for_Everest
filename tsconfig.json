{
    "extends": "@electron-toolkit/tsconfig/tsconfig.json",
    "compilerOptions": {
        "allowJs": true,
        "skipLibCheck": true,
        "baseUrl": ".",
        "paths": {
            "@renderer/*": [
                "src/renderer/*"
            ],
            "@main/*": [
                "src/main/*"
            ],
            "@preload/*": [
                "src/preload/*"
            ]
        }
    }
}